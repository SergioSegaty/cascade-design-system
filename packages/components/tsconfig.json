{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "types": ["react", "react-dom"],
    "paths": {
      "@/*": ["./src/*"],
    }
  },
  "references": [
    {"path": "../types"}
  ],
  "include": ["src"],
  "exclude": ["dist", "node_modules", "**/*.stories.tsx", "**/*.test.tsx"]
}